# ─────────────────────────────────────────────────────────────────────────
#  Theme Builder — environment configuration TEMPLATE
# ─────────────────────────────────────────────────────────────────────────
#  Setup:  copy this file to `.env`  and fill in real values.
#            cp .env.example .env
#
#  HOW VITE ENV VARS WORK:
#   • Only VITE_-prefixed vars reach the app (via import.meta.env.VITE_xxx).
#   • VITE_ vars are INLINED INTO THE BROWSER BUNDLE at build time — anyone
#     can read them in the shipped JS. They are NOT secret. This file is for
#     per-environment CONFIG only; a genuine secret must live server-side.
#   • Restart the dev server after editing `.env` — env vars are read at boot.
#
#  This template IS committed. The real `.env` is gitignored.
# ─────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────
# Backend host — MUST be https. apiConfig.ts derives the theme-builder API
# base and the CRM-handler URL from this host.
VITE_API_HOST=https://your-backend-host.example.com

# ── GHL marketplace identity ─────────────────────────────────────────────
# Marketplace app id — used in the postMessage SSO handshake and the
# CRM-handler request body.
VITE_APP_ID=your-ghl-marketplace-app-id

# App key identifying this marketplace app to the backend.
VITE_APP_KEY=app_theme_builder

# ── Local-dev fallbacks ──────────────────────────────────────────────────
# Used ONLY outside the GHL iframe (local dev) or if the SSO handshake
# fails. Inside the iframe the real per-user values come from GHL.

# Dev fallback company id.
VITE_DEV_COMPANY_ID=your-dev-fallback-company-id

# Dev fallback SSO token — a per-session value that expires.
VITE_SSO_TOKEN=your-dev-fallback-sso-token

# SSO token for the CRM-handler proxy call (useSubaccounts).
VITE_CRM_SSO_TOKEN=your-crm-handler-sso-token
